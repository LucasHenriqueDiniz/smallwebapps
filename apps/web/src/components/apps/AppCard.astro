---
import type { AppDefinition } from "@smallwebapps/data";

interface Props {
  app: AppDefinition;
}

const { app } = Astro.props;
---

<article class="flex h-full flex-col rounded-[2rem] border border-slate-200 bg-white p-6 shadow-soft transition hover:-translate-y-0.5 hover:border-orange-200">
  <div class="mb-5 flex items-start justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">{app.category}</p>
      <h3 class="mt-2 text-2xl font-semibold text-slate-950">{app.name}</h3>
    </div>
    <span class:list={["rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em]", app.status === "live" ? "bg-teal-100 text-teal-800" : "bg-orange-100 text-orange-800"]}>
      {app.status === "live" ? "Live" : "Coming soon"}
    </span>
  </div>

  <p class="text-sm leading-6 text-slate-600">{app.shortDescription}</p>

  <ul class="mt-5 flex flex-wrap gap-2">
    {
      app.tags.slice(0, 3).map((tag) => (
        <li class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-600 ring-1 ring-slate-200">{tag}</li>
      ))
    }
  </ul>

  <div class="mt-6">
    <a
      href={app.landingUrl}
      class="inline-flex items-center rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white transition hover:bg-orange-600"
    >
      {app.implemented ? "Open app page" : "View details"}
    </a>
  </div>
</article>
