---
import type { AppFaq } from "@smallwebapps/data";

interface Props {
  items: AppFaq[];
}

const { items } = Astro.props;
---

<section class="section-shell pt-10">
  <div class="card-surface rounded-[2rem] p-7 md:p-8">
    <div class="mb-6">
      <span class="eyebrow">FAQ</span>
      <h2 class="mt-4 text-2xl font-semibold text-slate-950">Questions users will likely ask before they trust the tool</h2>
    </div>

    <div class="space-y-4">
      {
        items.map((item) => (
          <details class="rounded-[1.5rem] border border-slate-200 bg-white px-5 py-4">
            <summary class="cursor-pointer list-none text-base font-semibold text-slate-900">{item.question}</summary>
            <p class="mt-3 text-sm leading-6 text-slate-600">{item.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
