---
import type { AppDefinition } from "@smallwebapps/data";

interface Props {
  items: AppDefinition[];
  title?: string;
  eyebrow?: string;
  viewAllHref?: string;
}

const {
  items,
  title = "Similar tools",
  eyebrow = "Related tools",
  viewAllHref = "/apps",
} = Astro.props;
---

{items.length > 0 && (
<section class="related-tools">
  <div class="related-inner">
    <div class="related-head">
      <div>
        <span>{eyebrow}</span>
        <h2>{title}</h2>
      </div>
      <a href={viewAllHref}>See all tools</a>
    </div>

    <div class="related-grid">
      {
        items.map((item) => (
          <a href={item.landingUrl} class="related-card">
            <div class="related-meta">
              <span>{item.status === "live" ? "Live" : "Soon"}</span>
              <small>{item.category}</small>
            </div>
            <h3>{item.name}</h3>
            <p>{item.shortDescription}</p>
            <div class="related-tags">
              {item.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
)}

<style>
.related-tools {
  margin-top: 34px;
  border-top: 1px solid var(--border);
  padding-top: 28px;
}

.related-inner {
  border: 1px solid var(--border);
  border-radius: 18px;
  background: var(--card-bg);
  box-shadow: var(--shadow);
  padding: 22px;
}

.related-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 18px;
}

.related-head span {
  display: block;
  color: var(--muted);
  font-size: .68rem;
  font-weight: 800;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.related-head h2 {
  color: var(--text);
  font-size: 1.15rem;
  font-weight: 800;
  margin: 6px 0 0;
  letter-spacing: 0;
}

.related-head a {
  color: var(--blue);
  flex-shrink: 0;
  font-size: .84rem;
  font-weight: 700;
  text-decoration: none;
}

.related-grid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.related-card {
  border: 1px solid var(--border);
  border-radius: 12px;
  background: var(--page-bg);
  color: inherit;
  min-width: 0;
  padding: 16px;
  text-decoration: none;
  transition: border-color .16s, transform .16s, box-shadow .16s;
}

.related-card:hover {
  border-color: var(--blue);
  box-shadow: 0 10px 24px rgba(26, 115, 232, .1);
  transform: translateY(-2px);
}

.related-meta {
  align-items: center;
  display: flex;
  gap: 8px;
  justify-content: space-between;
  min-width: 0;
}

.related-meta span {
  background: #dcfce7;
  border-radius: 999px;
  color: #15803d;
  flex-shrink: 0;
  font-size: .62rem;
  font-weight: 800;
  padding: 3px 8px;
  text-transform: uppercase;
}

.related-meta small {
  color: var(--muted);
  font-size: .7rem;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.related-card h3 {
  color: var(--text);
  font-size: .95rem;
  font-weight: 800;
  line-height: 1.25;
  margin: 12px 0 0;
}

.related-card p {
  color: var(--muted);
  display: -webkit-box;
  font-size: .78rem;
  line-height: 1.45;
  margin: 7px 0 0;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.related-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 12px;
}

.related-tags span {
  background: var(--input-bg);
  border: 1px solid var(--border);
  border-radius: 999px;
  color: var(--muted);
  font-size: .68rem;
  font-weight: 700;
  padding: 4px 8px;
}

:global([data-theme="dark"]) .related-meta span {
  background: rgba(34, 197, 94, .15);
  color: #86efac;
}

@media (max-width: 860px) {
  .related-grid { grid-template-columns: 1fr; }
  .related-head { align-items: flex-start; flex-direction: column; }
}
</style>
