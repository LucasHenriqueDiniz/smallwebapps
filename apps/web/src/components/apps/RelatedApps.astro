---
import type { AppDefinition } from "@smallwebapps/data";

interface Props {
  items: AppDefinition[];
}

const { items } = Astro.props;
---

<section class="section-shell pt-10">
  <div class="card-surface rounded-[2rem] p-7 md:p-8">
    <div class="mb-6 flex items-end justify-between gap-4">
      <div>
        <span class="eyebrow">Related apps</span>
        <h2 class="mt-4 text-2xl font-semibold text-slate-950">Keep the user inside the product graph</h2>
      </div>
      <a href="/apps" class="text-sm font-semibold text-orange-700">See all apps</a>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {
        items.map((item) => (
          <a href={item.landingUrl} class="rounded-[1.5rem] border border-slate-200 bg-white p-5 transition hover:-translate-y-0.5 hover:border-orange-200">
            <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">{item.category}</div>
            <h3 class="mt-2 text-lg font-semibold text-slate-950">{item.name}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">{item.shortDescription}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>
