---
interface Props {
  name: string;
  category: string;
  shortDescription: string;
  appUrl: string;
  color?: string;
  icon?: string;
}
const { name, category, shortDescription, appUrl, color = '#1a73e8', icon } = Astro.props;
---

<a href={appUrl} class="tool-card" data-category={category}>
  <div class="tool-icon" style={`background: ${color}18`}>
    {icon ? (
      <Fragment set:html={icon} />
    ) : (
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2">
        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
        <polyline points="14,2 14,8 20,8"/>
      </svg>
    )}
  </div>
  <div class="tool-info">
    <h4>{name}</h4>
    <span class="tool-cat" style={`color: ${color}`}>{category}</span>
    <p>{shortDescription}</p>
  </div>
  <div class="tool-arrow">→</div>
</a>

<style>
.tool-card {
  background: var(--card-bg);
  border-radius: 16px;
  padding: 18px 20px;
  display: flex;
  align-items: flex-start;
  gap: 14px;
  box-shadow: var(--shadow);
  border: 1.5px solid var(--card-border);
  transition:
    border-color 0.18s,
    transform 0.18s cubic-bezier(.4,0,.2,1),
    box-shadow 0.18s;
  text-decoration: none;
  color: inherit;
  position: relative;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
}
.tool-card:hover {
  border-color: var(--blue);
  transform: translateY(-3px);
  box-shadow: 0 10px 28px rgba(26,115,232,0.13);
}
.tool-card:active {
  transform: translateY(0) scale(0.97);
  box-shadow: 0 2px 8px rgba(26,115,232,0.1);
  border-color: var(--blue-dark);
  transition: transform 0.08s, box-shadow 0.08s;
}
.tool-icon {
  width: 44px; height: 44px;
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.tool-info { flex: 1; min-width: 0; }
.tool-info h4 {
  font-size: 0.9rem; font-weight: 700; color: var(--text);
  margin: 0 0 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.tool-cat { font-size: 0.72rem; font-weight: 600; }
.tool-info p {
  font-size: 0.77rem; color: var(--muted); margin-top: 4px;
  line-height: 1.4; display: -webkit-box;
  -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.tool-arrow {
  font-size: 1rem; color: #ccc;
  align-self: center; flex-shrink: 0;
  transition: color 0.15s, transform 0.15s;
}
.tool-card:hover .tool-arrow {
  color: var(--blue); transform: translateX(3px);
}
</style>
