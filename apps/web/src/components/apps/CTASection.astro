---
interface Props {
  title: string;
  copy: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const { title, copy, primaryHref, primaryLabel, secondaryHref, secondaryLabel } = Astro.props;
---

<section class="section-shell pt-10">
  <div class="rounded-[2.5rem] bg-slate-950 px-8 py-10 text-white shadow-soft md:px-10">
    <div class="grid gap-6 md:grid-cols-[1.3fr_0.7fr] md:items-end">
      <div>
        <span class="eyebrow border-white/10 bg-white/10 text-slate-200">Next step</span>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight">{title}</h2>
        <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">{copy}</p>
      </div>

      <div class="flex flex-wrap gap-3 md:justify-end">
        <a href={primaryHref} class="inline-flex rounded-full bg-orange-500 px-5 py-3 text-sm font-semibold text-white transition hover:bg-orange-400">
          {primaryLabel}
        </a>
        {secondaryHref && secondaryLabel && (
          <a href={secondaryHref} class="inline-flex rounded-full border border-white/20 bg-white/5 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10">
            {secondaryLabel}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
