---
interface Props {
  label: string;
  description: string;
  count: string;
  colorClass: string;
  href: string;
  featuredTool: { name: string; href: string };
  icon: string;
}

const { label, description, count, colorClass, href, featuredTool, icon } = Astro.props;
---

<a href={href} class={`group flex flex-col rounded-2xl overflow-hidden shadow-soft transition hover:-translate-y-1 hover:shadow-lg ${colorClass}`}>
  <div class="flex flex-col flex-1 p-5 gap-3">
    <div class="flex items-start justify-between">
      <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-white/20 text-white">
        <Fragment set:html={icon} />
      </div>
      <span class="rounded-full bg-white/20 px-2.5 py-1 text-xs font-semibold text-white">
        {count}
      </span>
    </div>
    <div class="flex items-end justify-between gap-2 mt-auto">
      <div>
        <div class="text-lg font-bold text-white leading-tight">{label}</div>
        <div class="text-sm text-white/80 mt-0.5">{description}</div>
      </div>
      <span class="text-white/80 text-xl font-light shrink-0">→</span>
    </div>
  </div>
  <div class="bg-white flex items-center justify-between px-5 py-3 gap-2">
    <span class="text-xs text-slate-500">Featured Tool:</span>
    <a
      href={featuredTool.href}
      class="text-xs font-semibold hover:underline"
      style={`color: var(--feat-color)`}
      onclick="event.stopPropagation()"
    >
      {featuredTool.name}
    </a>
  </div>
</a>

<style>
  a[href] .bg-white a {
    color: inherit;
  }
</style>
