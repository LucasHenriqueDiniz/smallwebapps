---
import { navItems, siteConfig } from "@/lib/site";
---

<header class="sticky top-0 z-40 border-b border-slate-200/80 bg-white/80 backdrop-blur-xl">
  <div class="section-shell flex items-center justify-between py-4">
    <a href="/" class="flex items-center gap-3">
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-orange-500 font-bold text-white shadow-soft">
        SW
      </span>
      <div>
        <div class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Small Web Apps</div>
        <div class="text-sm text-slate-700">{siteConfig.tagline}</div>
      </div>
    </a>

    <nav class="hidden items-center gap-5 text-sm font-medium text-slate-700 md:flex">
      {
        navItems.map((item) => (
          <a href={item.href} class="transition hover:text-orange-600">
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

