---
---
<div class="cookie-banner" id="cookie-banner" role="dialog" aria-label="Cookie consent">
  <div class="cb-inner">
    <div class="cb-text">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <p>
        We use cookies to serve ads and analyse traffic.
        See our <a href="/privacy">Privacy Policy</a> for details.
      </p>
    </div>
    <div class="cb-actions">
      <button class="cb-decline" id="cb-decline">Decline</button>
      <button class="cb-accept"  id="cb-accept">Accept all</button>
    </div>
  </div>
</div>

<script>
  const COOKIE_KEY = 'swa_consent';
  const banner     = document.getElementById('cookie-banner')!;

  function getConsent(): string | null {
    return localStorage.getItem(COOKIE_KEY);
  }

  function setConsent(value: 'granted' | 'denied') {
    localStorage.setItem(COOKIE_KEY, value);
    banner.style.display = 'none';

    // Update Google Consent Mode v2
    if (typeof (window as any).gtag === 'function') {
      (window as any).gtag('consent', 'update', {
        ad_storage:              value === 'granted' ? 'granted' : 'denied',
        analytics_storage:       value === 'granted' ? 'granted' : 'denied',
        ad_user_data:            value === 'granted' ? 'granted' : 'denied',
        ad_personalization:      value === 'granted' ? 'granted' : 'denied',
      });
    }
  }

  // Show only if no prior choice
  if (!getConsent()) {
    banner.style.display = 'block';
  }

  document.getElementById('cb-accept')?.addEventListener('click',  () => setConsent('granted'));
  document.getElementById('cb-decline')?.addEventListener('click', () => setConsent('denied'));
</script>

<style>
.cookie-banner {
  display: none; /* shown by JS when no consent stored */
  position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%);
  z-index: 9999;
  width: calc(100% - 40px); max-width: 760px;
  background: #1a1a2e;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px;
  padding: 16px 20px;
  box-shadow: 0 8px 40px rgba(0,0,0,0.35);
  font-family: 'Inter', sans-serif;
  animation: slideUp 0.3s cubic-bezier(.4,0,.2,1) both;
}
/* Light mode: use a white banner */
:root:not([data-theme="dark"]) .cookie-banner {
  background: #ffffff;
  border: 1px solid #e4edf8;
  box-shadow: 0 8px 40px rgba(0,0,0,0.14);
}
:root:not([data-theme="dark"]) .cb-text { color: #475569; }
:root:not([data-theme="dark"]) .cb-text svg { color: #1a73e8; }
:root:not([data-theme="dark"]) .cb-text a { color: #1a73e8; }
:root:not([data-theme="dark"]) .cb-decline {
  color: #64748b; border-color: #e0e7ef; background: transparent;
}
:root:not([data-theme="dark"]) .cb-decline:hover { background: #f1f5fb; }
@keyframes slideUp {
  from { opacity: 0; transform: translateX(-50%) translateY(16px); }
  to   { opacity: 1; transform: translateX(-50%) translateY(0); }
}

.cb-inner {
  display: flex; align-items: center; justify-content: space-between;
  gap: 16px; flex-wrap: wrap;
}

.cb-text {
  display: flex; align-items: center; gap: 10px;
  color: rgba(255,255,255,0.8); font-size: 0.84rem; line-height: 1.5; flex: 1;
}
.cb-text svg { flex-shrink: 0; color: #60a5fa; }
.cb-text p   { margin: 0; }
.cb-text a   { color: #60a5fa; text-decoration: underline; text-underline-offset: 2px; }
.cb-text a:hover { color: #93c5fd; }

.cb-actions { display: flex; gap: 10px; flex-shrink: 0; }
.cb-decline {
  background: transparent; color: rgba(255,255,255,0.55);
  border: 1px solid rgba(255,255,255,0.2);
  padding: 8px 18px; border-radius: 20px;
  font-size: 0.82rem; font-weight: 500; cursor: pointer;
  font-family: 'Inter', sans-serif;
  transition: border-color 0.15s, color 0.15s;
}
.cb-decline:hover { border-color: rgba(255,255,255,0.4); color: white; }
.cb-accept {
  background: #1a73e8; color: white;
  border: none; padding: 8px 20px; border-radius: 20px;
  font-size: 0.82rem; font-weight: 600; cursor: pointer;
  font-family: 'Inter', sans-serif;
  box-shadow: 0 2px 8px rgba(26,115,232,0.4);
  transition: background 0.15s, transform 0.1s;
}
.cb-accept:hover  { background: #1557b0; }
.cb-accept:active { transform: scale(0.97); }

@media (max-width: 540px) {
  .cb-inner { flex-direction: column; align-items: stretch; }
  .cb-actions { justify-content: flex-end; }
}
</style>
