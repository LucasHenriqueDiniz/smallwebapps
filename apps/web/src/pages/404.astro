---
import MainLayout from "@/components/layout/MainLayout.astro";
---

<MainLayout
  title="Page Not Found"
  description="The page you are looking for does not exist on Small Web Apps."
  canonicalPath="/404"
  noindex={true}
>
  <section class="static-page">
    <div class="static-inner">
      <span class="static-eyebrow">404</span>
      <h1>Page not found</h1>
      <div class="static-card">
        <p>The page you're looking for doesn't exist or may have moved.</p>
        <p>
          <a href="/">Go back home</a> or <a href="/apps">browse all tools</a>.
        </p>
      </div>
    </div>
  </section>
</MainLayout>

<style>
.static-page {
  max-width: 760px; margin: 0 auto; padding: 64px 24px 80px;
  font-family: 'Inter', sans-serif;
}
.static-inner { display: flex; flex-direction: column; gap: 20px; }
.static-eyebrow {
  display: inline-flex; align-items: center;
  background: rgba(26,115,232,.1); color: var(--blue);
  padding: 4px 14px; border-radius: 20px;
  font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em;
  width: fit-content;
}
h1 {
  font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 900;
  color: var(--text); letter-spacing: -.5px; line-height: 1.15; margin: 0;
}
.static-card {
  background: var(--surface-strong); border: 1px solid var(--border);
  border-radius: 20px; padding: 32px;
  display: flex; flex-direction: column; gap: 16px;
  box-shadow: var(--shadow);
}
.static-card p {
  font-size: .95rem; line-height: 1.8; color: var(--muted); margin: 0;
}
.static-card a { color: var(--blue); font-weight: 600; text-decoration: none; }
.static-card a:hover { text-decoration: underline; }
</style>
