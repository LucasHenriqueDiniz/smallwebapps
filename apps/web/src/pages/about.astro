---
import Header from "@/components/site/Header.astro";
import Footer from "@/components/site/Footer.astro";
import CookieBanner from "@/components/site/CookieBanner.astro";
import { siteConfig } from "@/lib/site";
import "../styles/global.css";

const pageTitle = "About Small Web Apps";
const pageDesc = "Learn about Small Web Apps, a collection of free browser-based utilities built with privacy and simplicity in mind.";
const canonicalUrl = new URL("/about", siteConfig.siteUrl).toString();
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle} | {siteConfig.name}</title>
  <meta name="description" content={pageDesc} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#1a73e8" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={new URL("/og/site.svg", siteConfig.siteUrl).toString()} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDesc} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <Header />

  <div class="about-page">
    <div class="about-container">
      <h1>About Small Web Apps</h1>

      <section class="about-section">
        <h2>Our Mission</h2>
        <p>
          Small Web Apps is a collection of 136+ free, browser-based utilities designed to solve everyday tasks
          with simplicity, speed, and privacy in mind. Every tool runs entirely in your browser — no uploads,
          no accounts, no servers required.
        </p>
      </section>

      <section class="about-section">
        <h2>Why We Built This</h2>
        <p>
          The web needed a better toolbox. Too many utility sites force you to create accounts, upload files to unknown servers,
          or wait for slow cloud processing. Small Web Apps flips the script: fast, local, and transparent.
          Whether you're formatting JSON, compressing images, or analyzing your YouTube history, your data never leaves your device.
        </p>
      </section>

      <section class="about-section">
        <h2>What Makes Us Different</h2>
        <ul class="about-list">
          <li><strong>100% Browser-Based:</strong> All processing happens locally in your browser using JavaScript and Web APIs. No server uploads, period.</li>
          <li><strong>Privacy First:</strong> We don't collect, log, or store your files. Refreshing the page clears everything from memory.</li>
          <li><strong>No Accounts or Paywalls:</strong> Sign up, login walls, and premium tiers don't exist here. Use any tool, anytime, free.</li>
          <li><strong>Fast & Reliable:</strong> Tools are optimized to run instantly on modern browsers without external dependencies.</li>
          <li><strong>Open Source:</strong> Source code is publicly available on GitHub, so you can verify security, fork, or contribute improvements.</li>
        </ul>
      </section>

      <section class="about-section">
        <h2>How We Maintain Quality</h2>
        <p>
          Each tool is tested, documented, and maintained regularly. Bugs are fixed quickly, and new features are added based on user feedback.
          We document limitations honestly—if a tool can't handle very large files or has narrow use cases, we say so upfront.
          You'll never find an overblown claim or deceptive marketing here.
        </p>
      </section>

      <section class="about-section">
        <h2>Built and Maintained By</h2>
        <p>
          Small Web Apps is built and maintained by <strong>Lucas Diniz</strong>, a developer passionate about creating simple, useful tools
          that respect user privacy. The project is a labor of love and a commitment to keeping the web free from unnecessary friction.
        </p>
      </section>

      <section class="about-section">
        <h2>Technical Philosophy</h2>
        <p>
          We use modern web standards (HTML5, CSS3, JavaScript ES2020+) and frameworks like React and Astro to build tools that:
        </p>
        <ul class="about-list">
          <li>Run in any modern browser without external file uploads</li>
          <li>Leverage native browser APIs for speed and security</li>
          <li>Gracefully degrade if JavaScript is disabled (where applicable)</li>
          <li>Load only the dependencies necessary for each tool</li>
          <li>Prioritize accessibility and mobile-friendly design</li>
        </ul>
      </section>

      <section class="about-section">
        <h2>Contact & Feedback</h2>
        <p>
          Found a bug? Have a feature request? Want to discuss something about the tools or privacy approach?
          Head over to the <a href="/contact">Contact page</a> to get in touch.
        </p>
      </section>

      <section class="about-section about-footer-section">
        <p>
          <em>Last updated: June 2026</em>
        </p>
        <div class="about-links">
          <a href="/privacy">Privacy Policy</a> •
          <a href="/terms">Terms of Service</a> •
          <a href="https://github.com/LucasHenriqueDiniz/smallwebapps" target="_blank" rel="noopener noreferrer">GitHub Repository</a>
        </div>
      </section>
    </div>
  </div>

  <Footer />
  <CookieBanner />
</body>
</html>

<style>
*, *::before, *::after { box-sizing: border-box; }

body {
  margin: 0;
  min-height: 100vh;
  background: var(--page-bg);
  color: var(--text);
  font-family: 'Inter', sans-serif;
}

.about-page {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 62px);
}

.about-container {
  max-width: 800px;
  width: 100%;
  margin: 0 auto;
  padding: 48px 24px 64px;
}

h1 {
  margin: 0 0 32px 0;
  font-size: clamp(2rem, 4vw, 2.8rem);
  font-weight: 800;
  line-height: 1.2;
  color: var(--text);
}

.about-section {
  margin-bottom: 40px;
}

.about-section h2 {
  margin: 0 0 16px 0;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--text);
  line-height: 1.3;
}

.about-section p {
  margin: 0 0 16px 0;
  font-size: 1rem;
  line-height: 1.7;
  color: var(--text);
}

.about-section p:last-child {
  margin-bottom: 0;
}

.about-list {
  margin: 16px 0 0 0;
  padding-left: 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.about-list li {
  font-size: 1rem;
  line-height: 1.6;
  color: var(--text);
}

.about-section a {
  color: var(--blue);
  text-decoration: none;
  font-weight: 600;
  transition: opacity 0.15s;
}

.about-section a:hover {
  opacity: 0.75;
}

.about-footer-section {
  margin-top: 48px;
  padding-top: 32px;
  border-top: 1px solid var(--border);
}

.about-footer-section p {
  font-size: 0.9rem;
  color: var(--muted);
  margin-bottom: 16px;
}

.about-links {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  font-size: 0.95rem;
}

.about-links a {
  color: var(--blue);
  text-decoration: none;
  font-weight: 600;
  transition: opacity 0.15s;
}

.about-links a:hover {
  opacity: 0.75;
}

@media (max-width: 640px) {
  .about-container {
    padding: 32px 16px 48px;
  }

  h1 {
    font-size: 1.8rem;
    margin-bottom: 24px;
  }

  .about-section h2 {
    font-size: 1.2rem;
  }

  .about-section {
    margin-bottom: 32px;
  }

  .about-list {
    padding-left: 20px;
    gap: 10px;
  }

  .about-list li {
    font-size: 0.95rem;
  }
}
</style>
