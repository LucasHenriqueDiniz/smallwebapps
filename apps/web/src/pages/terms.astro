---
import MainLayout from "@/components/layout/MainLayout.astro";
---

<MainLayout
  title="Terms of Service"
  description="Read the basic terms for using Small Web Apps and its free browser-based utilities."
  canonicalPath="/terms"
>
  <section class="static-page">
    <div class="static-inner">
      <span class="static-eyebrow">Terms</span>
      <h1>Simple terms for free<br/>browser-based utilities</h1>
      <div class="static-card">
        <p>Small Web Apps provides free tools and informational pages on an as-is basis.</p>
        <p>The site aims to be useful and honest, but it does not promise uninterrupted availability, perfect accuracy, or suitability for high-stakes use cases.</p>
        <p>Users remain responsible for reviewing outputs, protecting their own data, and deciding whether a tool is appropriate for a given workflow.</p>
        <p>Advertising may be used to keep the tools free. Ads must not be clicked to support the site, and automated, misleading, or incentivized ad interaction is not allowed.</p>
        <div class="static-highlight">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p>By using any tool on this site, you accept these terms. If you have questions, use the contact page.</p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
.static-page {
  max-width: 760px; margin: 0 auto; padding: 64px 24px 80px;
  font-family: 'Inter', sans-serif;
}
.static-inner { display: flex; flex-direction: column; gap: 20px; }
.static-eyebrow {
  display: inline-flex; align-items: center;
  background: rgba(26,115,232,.1); color: var(--blue);
  padding: 4px 14px; border-radius: 20px;
  font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em;
  width: fit-content;
}
h1 {
  font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 900;
  color: var(--text); letter-spacing: -.5px; line-height: 1.15; margin: 0;
}
.static-card {
  background: var(--surface-strong); border: 1px solid var(--border);
  border-radius: 20px; padding: 32px;
  display: flex; flex-direction: column; gap: 16px;
  box-shadow: var(--shadow);
}
.static-card p {
  font-size: .95rem; line-height: 1.8; color: var(--muted); margin: 0;
}
.static-highlight {
  display: flex; align-items: flex-start; gap: 12px;
  background: rgba(245,158,11,.07); border: 1px solid rgba(245,158,11,.2);
  border-radius: 12px; padding: 16px 18px; margin-top: 8px;
  color: #d97706;
}
.static-highlight svg { flex-shrink: 0; margin-top: 2px; }
.static-highlight p  { color: #d97706 !important; font-weight: 500; font-size: .88rem !important; line-height: 1.6 !important; }
</style>
