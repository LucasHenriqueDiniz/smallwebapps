---
import MainLayout from "@/components/layout/MainLayout.astro";
---

<MainLayout
  title="Terms"
  description="Read the basic terms for using Small Web Apps and its free browser-based utilities."
  canonicalPath="/terms"
>
  <section class="section-shell pt-12">
    <span class="eyebrow">Terms</span>
    <h1 class="mt-4 section-title">Simple terms for free browser-based utilities</h1>
    <div class="mt-8 card-surface rounded-[2rem] p-7 text-sm leading-7 text-slate-600 md:text-base">
      <p>Small Web Apps provides free tools and informational pages on an as-is basis.</p>
      <p class="mt-4">
        The site aims to be useful and honest, but it does not promise uninterrupted availability, perfect accuracy, or suitability for high-stakes use cases.
      </p>
      <p class="mt-4">
        Users remain responsible for reviewing outputs, protecting their own data, and deciding whether a tool is appropriate for a given workflow.
      </p>
    </div>
  </section>
</MainLayout>

