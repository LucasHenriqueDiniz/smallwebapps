---
import MainLayout from "@/components/layout/MainLayout.astro";
---

<MainLayout
  title="Contact"
  description="Contact Small Web Apps for feedback, bug reports, or tool requests."
  canonicalPath="/contact"
>
  <section class="section-shell pt-12">
    <span class="eyebrow">Contact</span>
    <h1 class="mt-4 section-title">Send feedback, bug reports, or tool requests</h1>
    <div class="mt-8 grid gap-5 md:grid-cols-2">
      <div class="card-surface rounded-[2rem] p-7 text-sm leading-7 text-slate-600 md:text-base">
        <p>
          <strong>For questions, bug reports, feature requests, or privacy inquiries:</strong>
        </p>
        <ul class="mt-4 space-y-2">
          <li><strong>Email:</strong> <a class="prose-link" href="mailto:lucas.hdo@hotmail.com">lucas.hdo@hotmail.com</a></li>
          <li><strong>GitHub Issues:</strong> <a class="prose-link" href="https://github.com/LucasHenriqueDiniz/smallwebapps/issues">github.com/LucasHenriqueDiniz/smallwebapps/issues</a></li>
          <li><strong>Response time:</strong> Typically within 7 days</li>
        </ul>
      </div>

      <div class="rounded-[2rem] bg-slate-950 p-7 text-white shadow-soft">
        <h2 class="text-xl font-semibold">Suggested contact targets</h2>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-slate-200">
          <li>Bug report for an embedded tool</li>
          <li>Guide topic request</li>
          <li>Feature request for YouTube analysis tools or JSON Formatter</li>
          <li>Monetization or partnership inquiry later on</li>
        </ul>
      </div>
    </div>
  </section>
</MainLayout>
