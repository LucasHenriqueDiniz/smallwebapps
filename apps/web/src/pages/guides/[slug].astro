---
import MainLayout from "@/components/layout/MainLayout.astro";
import CTASection from "@/components/apps/CTASection.astro";
import { guides } from "@/data/guides";

export function getStaticPaths() {
  return guides.map((guide) => ({
    params: { slug: guide.slug }
  }));
}

const guide = guides.find((item) => item.slug === Astro.params.slug);

if (!guide) {
  throw new Error(`Unknown guide slug: ${Astro.params.slug}`);
}

const contentMap = {
  "how-to-export-youtube-watch-history": {
    intro:
      "If you want to inspect your YouTube watch history locally, the first step is getting the correct export from Google Takeout. The important part is not just downloading a zip, but confirming that the export actually contains the watch-history data you expect to inspect.",
    points: [
      "Choose the YouTube and YouTube Music data sections carefully in Google Takeout.",
      "Keep the export local instead of immediately uploading it to third-party tools.",
      "Open the resulting files with the YouTube Watch History Analyzer inside Small Web Apps so the content stays inside the browser session."
    ]
  },
  "how-to-analyze-youtube-watch-history": {
    intro:
      "A lightweight local workflow is often enough to answer basic questions about your viewing history. You usually do not need a complex cloud dashboard to validate whether a file contains usable watch-history data and estimate how much history is present.",
    points: [
      "Start by validating the file locally in the YouTube Watch History Analyzer.",
      "Look for timestamps, watch links, and channel-related patterns before deeper parsing.",
      "Treat local inspection as the safest default until you genuinely need richer analytics."
    ]
  }
};

const content = contentMap[guide.slug as keyof typeof contentMap];
const canonicalUrl = `https://smallwebapps.com/guides/${guide.slug}/`;
const imageUrl = new URL(guide.image, "https://smallwebapps.com").toString();
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: guide.title,
  description: guide.description,
  image: imageUrl,
  estimatedCost: { "@type": "PriceSpecification", priceCurrency: "USD", price: "0" },
  step: content?.points.map((point, idx) => ({
    "@type": "HowToStep",
    position: idx + 1,
    name: point.split(".")[0],
    text: point
  })) || []
};
const structuredData = [
  howToSchema,
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: guide.title,
    description: guide.description,
    mainEntityOfPage: canonicalUrl,
    datePublished: guide.publishedDate,
    dateModified: guide.modifiedDate,
    image: imageUrl,
    author: {
      "@type": "Organization",
      name: "Small Web Apps",
      url: "https://smallwebapps.com/"
    },
    publisher: {
      "@type": "Organization",
      name: "Small Web Apps",
      url: "https://smallwebapps.com/",
      logo: {
        "@type": "ImageObject",
        url: "https://smallwebapps.com/favicon.svg"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://smallwebapps.com/" },
      { "@type": "ListItem", position: 2, name: "Guides", item: "https://smallwebapps.com/guides/" },
      { "@type": "ListItem", position: 3, name: guide.title, item: canonicalUrl }
    ]
  }
];
---

<MainLayout
  title={guide.title}
  description={guide.description}
  canonicalPath={`/guides/${guide.slug}`}
  image={guide.image}
  ogType="article"
  structuredData={structuredData}
>
  <section class="section-shell pt-12">
    <span class="eyebrow">{guide.category}</span>
    <h1 class="mt-4 section-title">{guide.title}</h1>
    <p class="mt-4 section-copy">{guide.description}</p>
    <div class="mt-5 flex flex-wrap gap-x-5 gap-y-2 text-sm text-slate-500">
      <span>Published <time datetime={guide.publishedDate}>June 2, 2026</time></span>
      <span>Updated <time datetime={guide.modifiedDate}>June 25, 2026</time></span>
      <span>By Small Web Apps</span>
    </div>
  </section>

  <section class="section-shell pt-10">
    <div class="max-w-3xl">
      <article class="card-surface rounded-[2rem] p-7">
        <p class="text-sm leading-7 text-slate-600 md:text-base">{content.intro}</p>
        <ul class="mt-6 space-y-4 text-sm leading-7 text-slate-600 md:text-base">
          {content.points.map((point) => <li>{point}</li>)}
        </ul>
        <p class="mt-6 text-sm leading-7 text-slate-600 md:text-base">
          The purpose of this guide is to strengthen the app page with supporting context, not to replace the app itself.
        </p>
      </article>
    </div>
  </section>

  <CTASection
    title="Continue into the actual tool"
    copy="Use the guide to understand the workflow, then move into the app page for local interaction."
    primaryHref="/apps/tubetrace"
    primaryLabel="Open YouTube analyzer"
    secondaryHref="/guides"
    secondaryLabel="Back to guides"
  />
</MainLayout>

