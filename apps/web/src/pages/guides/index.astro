---
import MainLayout from "@/components/layout/MainLayout.astro";
import AdSlot from "@/components/ads/AdSlot.astro";
import { guides } from "@/data/guides";
---

<MainLayout
  title="Guides"
  description="Read Small Web Apps guides that support embedded tools, especially local workflows around YouTube history and browser-based utilities."
  canonicalPath="/guides"
>
  <section class="section-shell pt-12">
    <span class="eyebrow">Guides</span>
    <h1 class="mt-4 section-title">Supporting content that strengthens app discovery and trust</h1>
    <p class="mt-4 section-copy">
      Guides are part of the product strategy, not filler. They help users reach the right app page with more context, clearer expectations, and better privacy understanding.
    </p>
  </section>

  <section class="section-shell pt-10">
    <div class="grid gap-5 md:grid-cols-2">
      {
        guides.map((guide) => (
          <article class="card-surface rounded-[2rem] p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">{guide.category}</p>
            <h2 class="mt-3 text-2xl font-semibold text-slate-950">
              <a href={`/guides/${guide.slug}`} class="hover:text-orange-600">
                {guide.title}
              </a>
            </h2>
            <p class="mt-4 text-sm leading-7 text-slate-600">{guide.description}</p>
            <p class="mt-5 text-xs font-semibold uppercase tracking-[0.18em] text-orange-700">{guide.publishedLabel}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section-shell pt-10">
    <AdSlot label="Guide index ad placeholder with reserved space" />
  </section>
</MainLayout>

