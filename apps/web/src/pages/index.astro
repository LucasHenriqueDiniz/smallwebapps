---
import MainLayout from "@/components/layout/MainLayout.astro";
import ToolCard from "@/components/apps/ToolCard.astro";
import FeaturedCard from "@/components/apps/FeaturedCard.astro";
import { apps } from "@/data/apps";
import { siteConfig } from "@/lib/site";

const POPULAR_TOOL_LIMIT = 12;
const categoryUrl = (category: string) => `/apps?cat=${encodeURIComponent(category).replaceAll("%20", "+")}`;
const appCount = (category: string) => apps.filter((app) => app.category === category).length;

const categories = [
  {
    label: "PDF Tools",
    description: "Solve Your PDF Problems",
    count: `${appCount("PDF Tools")} tools`,
    color: "cat-purple",
    href: categoryUrl("PDF Tools"),
    featuredTool: "PDF Merger",
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/></svg>`,
  },
  {
    label: "Image Tools",
    description: "Solve Your Image Problems",
    count: `${appCount("Image / Inspection")} tools`,
    color: "cat-orange",
    href: categoryUrl("Image / Inspection"),
    featuredTool: "Image Resizer",
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>`,
  },
  {
    label: "Developer Tools",
    description: "Format & Validate Code",
    count: `${appCount("Developer Tools")} tools`,
    color: "cat-red",
    href: categoryUrl("Developer Tools"),
    featuredTool: "JSON Formatter",
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    label: "AI Detectors",
    description: "Check AI-Generated Content",
    count: "AI tools",
    color: "cat-blue",
    href: "/apps?q=ai",
    featuredTool: "AI Image Checker",
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
  },
  {
    label: "Data Tools",
    description: "Convert & Clean Files",
    count: `${appCount("Data Tools")} tools`,
    color: "cat-teal",
    href: categoryUrl("Data Tools"),
    featuredTool: "CSV Cleaner",
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>`,
  },
];

const stats = [
  { value: `${apps.length}`, label: "Online Tools" },
  { value: "100%", label: "Browser-Based" },
  { value: "Local", label: "Client-Side" },
  { value: "Free", label: "No Accounts" },
];

const toolColors: Record<string, string> = {
  "YouTube / Data":    "#dc2626",
  "Developer Tools":   "#2563eb",
  "Image / Inspection":"#9333ea",
  "Data Tools":        "#0d9488",
  "PDF Tools":         "#7c3aed",
};

const toolIcons: Record<string, string> = {
  "YouTube / Data": `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2"><polygon points="23,7 16,12 23,17"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>`,
  "Developer Tools": `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2"><polyline points="16,18 22,12 16,6"/><polyline points="8,6 2,12 8,18"/></svg>`,
  "Image / Inspection": `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#9333ea" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>`,
  "Data Tools": `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0d9488" stroke-width="2"><path d="M8 6h13M8 12h13M8 18h13"/><path d="M3 6h.01M3 12h.01M3 18h.01"/></svg>`,
  "PDF Tools": `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/></svg>`,
};

const popularSlugs = [
  "json-formatter",
  "pdf-merge",
  "image-resize",
  "csv-cleaner",
  "ai-image-checker",
  "youtube-title-counter",
  "pdf-compress",
  "password-generator",
  "image-to-pdf",
  "csv-to-json",
  "regex-tester",
  "file-hash",
];
const popularTools = popularSlugs
  .flatMap((slug) => {
    const app = apps.find((item) => item.slug === slug);
    return app ? [app] : [];
  })
  .slice(0, POPULAR_TOOL_LIMIT);

const featured = [
  {
    title: "JSON Formatter",
    desc: "Format, validate, and pretty-print JSON instantly — no server, no account.",
    href: "/apps/json-formatter",
    bg: "#dbeafe",
    accent: "#2563eb",
    badge: "Dev Tool",
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><polyline points="16,18 22,12 16,6"/><polyline points="8,6 2,12 8,18"/></svg>`,
  },
  {
    title: "AI Image Checker",
    desc: "Inspect images for AI-generation signals, metadata clues, and visual artifacts.",
    href: "/apps/ai-image-checker",
    bg: "#ede9fe",
    accent: "#7c3aed",
    badge: "AI",
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>`,
  },
  {
    title: "YouTube Watch History Analyzer",
    desc: "Analyze your YouTube watch history from a Google Takeout export, fully local.",
    href: "/apps/tubetrace",
    bg: "#dcfce7",
    accent: "#16a34a",
    badge: "YouTube",
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><polygon points="23,7 16,12 23,17"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>`,
  },
  {
    title: "CSV Cleaner",
    desc: "Preview, trim whitespace, and normalize CSV files — stays in the browser.",
    href: "/apps/csv-cleaner",
    bg: "#fce7f3",
    accent: "#be185d",
    badge: "Data",
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>`,
  },
];
---

<MainLayout title={siteConfig.title} description={siteConfig.description} canonicalPath="/">

<!-- ═══════════════ HERO ═══════════════ -->
<section class="hero">
  <div class="hero-bg">
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>
    <div class="shape shape-4"></div>
    <div class="shape shape-5"></div>
  </div>
  <div class="hero-content">
    <!-- Eyebrow -->
    <div class="hero-eyebrow">
      <span class="hero-eyebrow-dot"></span>
      All tools run in your browser
    </div>

    <h1 class="hero-title">
      Free Tools to Make
      <span class="hero-highlight" id="hero-hl">
        <span class="hero-word" id="hero-word"></span><span class="hero-cursor" id="hero-cursor"></span>
      </span>
      Simple
    </h1>

    <p class="hero-sub">PDF, image, developer &amp; AI tools. No uploads. No accounts. No limits.</p>

    <!-- Search bar -->
    <div class="hero-search-wrap">
      <div class="hero-search" onclick="document.getElementById('hero-search-input').focus()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hero-search-icon"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input type="text" placeholder="Search tools — try &quot;json&quot;, &quot;image&quot;, &quot;csv&quot;…" id="hero-search-input" />
        <button class="search-btn" id="hero-search-btn">Search</button>
      </div>
      <!-- Quick links -->
      <div class="hero-quick">
        <span class="hero-quick-label">Popular:</span>
        <a href="/apps/json-formatter"   class="hero-quick-link">JSON Formatter</a>
        <a href="/apps/ai-image-checker" class="hero-quick-link">AI Image Checker</a>
        <a href="/apps/youtube-title-counter" class="hero-quick-link">YouTube Title Counter</a>
      </div>
    </div>
  </div>

  <!-- Category cards -->
  <div class="category-cards">
    {categories.map((cat, i) => (
      <a href={cat.href} class={`cat-card ${cat.color}`} style={`animation-delay: ${i * 0.07}s`}>
        <div class="cat-top">
          <div class="cat-header">
            <div class="cat-icon">
              <Fragment set:html={cat.icon} />
            </div>
            <span class="cat-badge">{cat.count}</span>
          </div>
          <div class="cat-info">
            <h3>{cat.label}</h3>
            <p>{cat.description}</p>
          </div>
        </div>
        <div class="cat-arrow-row">
          <div class="cat-arrow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>
        <div class="cat-featured">
          <span class="cat-featured-label">Featured:</span>
          <span class="cat-featured-name">{cat.featuredTool}</span>
        </div>
      </a>
    ))}
  </div>

  <!-- Stats bar -->
  <div class="stats-bar">
    {stats.map((s, i) => (
      <>
        <div class="stat">
          <span class="stat-num">{s.value}</span>
          <span class="stat-label">{s.label}</span>
        </div>
        {i < stats.length - 1 && <div class="stat-divider"></div>}
      </>
    ))}
  </div>
</section>

<!-- ═══════════════ POPULAR TOOLS ═══════════════ -->
<section class="popular">
  <div class="popular-inner">
    <h2 class="section-title-clone">Our Most Popular Tools</h2>
    <p class="section-sub-clone">All free, browser-based, no sign-up required</p>

    <div class="tabs">
      <button class="tab-btn active" data-tab="All">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/><rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/></svg>
        Top {POPULAR_TOOL_LIMIT}
      </button>
      <button class="tab-btn" data-tab="PDF Tools">PDF</button>
      <button class="tab-btn" data-tab="Developer Tools">Developer</button>
      <button class="tab-btn" data-tab="YouTube / Data">YouTube Analysis</button>
      <button class="tab-btn" data-tab="Image / Inspection">Image</button>
      <button class="tab-btn" data-tab="Data Tools">Data</button>
    </div>

    <div class="tools-grid" id="tools-grid">
      {popularTools.map(tool => (
        <ToolCard
          name={tool.name}
          category={tool.category}
          shortDescription={tool.shortDescription}
          appUrl={tool.appUrl}
          color={toolColors[tool.category] ?? '#1a73e8'}
          icon={toolIcons[tool.category]}
        />
      ))}
    </div>

    <div class="all-tools-wrap">
      <a href="/apps" class="all-tools-btn">All Tools →</a>
    </div>
  </div>
</section>

<!-- ═══════════════ FEATURED TOOLS ═══════════════ -->
<section class="featured">
  <div class="featured-inner">
    <div class="featured-header">
      <div>
        <h2 class="section-title-clone" style="text-align:left">Free Tools You'd Usually Pay For</h2>
        <p class="section-sub-sm">No limits. No sign-up. Open the tool and start immediately.</p>
      </div>
      <a href="/apps" class="see-all-btn">See all tools →</a>
    </div>

    <div class="featured-cards">
      {featured.map(item => (
        <FeaturedCard
          title={item.title}
          desc={item.desc}
          href={item.href}
          bg={item.bg}
          accent={item.accent}
          badge={item.badge}
          icon={item.icon}
        />
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════ CTA ═══════════════ -->
<section class="cta-section">
  <!-- background decoration -->
  <div class="cta-bg" aria-hidden="true">
    <div class="cta-blob cta-blob-1"></div>
    <div class="cta-blob cta-blob-2"></div>
    <div class="cta-grid"></div>
  </div>

  <div class="cta-inner">
    <!-- Left: copy -->
    <div class="cta-copy">
      <div class="cta-eyebrow">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Privacy first, always
      </div>
      <h2 class="cta-title">Your files never<br/>leave your device.</h2>
      <p class="cta-desc">Every tool runs entirely in your browser. No server receives your data, no account is required, and there are no rate limits.</p>
      <div class="cta-actions">
        <a href="/apps" class="cta-primary">
          Browse all tools
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/guides" class="cta-secondary">Read our guides</a>
      </div>
    </div>

    <!-- Right: feature cards -->
    <div class="cta-cards">
      <div class="cta-card">
        <div class="cta-card-icon" style="background:#1e40af20">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div>
          <strong>Private by design</strong>
          <p>Tools process data locally. Nothing is sent to any server.</p>
        </div>
      </div>
      <div class="cta-card">
        <div class="cta-card-icon" style="background:#065f4620">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
        </div>
        <div>
          <strong>Instant results</strong>
          <p>No upload queue. No waiting. Open a tool and start immediately.</p>
        </div>
      </div>
      <div class="cta-card">
        <div class="cta-card-icon" style="background:#78350f20">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        </div>
        <div>
          <strong>Free forever</strong>
          <p>No paywalls, no premium tiers. Every tool is free with no hidden limits.</p>
        </div>
      </div>
      <div class="cta-card">
        <div class="cta-card-icon" style="background:#4c1d9520">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="2"><polyline points="16,18 22,12 16,6"/><polyline points="8,6 2,12 8,18"/></svg>
        </div>
        <div>
          <strong>Built for developers</strong>
          <p>JSON, CSV, YAML and more. Format, validate, clean right in the browser.</p>
        </div>
      </div>
    </div>
  </div>
</section>

</MainLayout>

<script>
  // ── Typewriter hero — box always = text size (CSS fit-content) ──
  const WORDS    = ['Your Life', 'Your Work', 'Every Day', 'Your Tasks'];
  const wordEl   = document.getElementById('hero-word')!;
  const cursor   = document.getElementById('hero-cursor')!;

  const PAUSE_MS = 1800;
  const TYPE_MS  = 75;
  const ERASE_MS = 40;

  const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));

  async function typeIn(word: string) {
    cursor.style.animation = 'none'; cursor.style.opacity = '1';
    for (let i = 0; i <= word.length; i++) {
      wordEl.textContent = word.slice(0, i);
      await sleep(TYPE_MS);
    }
    cursor.style.animation = '';
  }

  async function eraseOut() {
    cursor.style.animation = 'none'; cursor.style.opacity = '1';
    const text = wordEl.textContent ?? '';
    for (let i = text.length; i >= 0; i--) {
      wordEl.textContent = text.slice(0, i);
      await sleep(ERASE_MS);
    }
  }

  async function run() {
    await typeIn(WORDS[0]);
    let idx = 0;
    while (true) {
      await sleep(PAUSE_MS);
      await eraseOut();
      idx = (idx + 1) % WORDS.length;
      await typeIn(WORDS[idx]);
    }
  }

  run();

  // Hero search
  const heroInput = document.getElementById('hero-search-input') as HTMLInputElement | null;
  const heroBtn   = document.getElementById('hero-search-btn');
  function doSearch() {
    const q = heroInput?.value.trim();
    if (q) window.location.href = `/apps?q=${encodeURIComponent(q)}`;
  }
  heroBtn?.addEventListener('click', doSearch);
  heroInput?.addEventListener('keydown', (e) => { if (e.key === 'Enter') doSearch(); });

  // Tab filter
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const tab = (btn as HTMLElement).dataset.tab ?? 'All';
      document.querySelectorAll('.tool-card').forEach(card => {
        const cat = (card as HTMLElement).dataset.category ?? '';
        (card as HTMLElement).style.display = (tab === 'All' || cat === tab) ? '' : 'none';
      });
    });
  });
</script>

<style>
*, *::before, *::after { box-sizing: border-box; }

/* ─ shared ─ */
.section-title-clone {
  font-size: 2rem; font-weight: 800; text-align: center;
  margin-bottom: 8px; color: var(--text); font-family: 'Inter', sans-serif;
}
.section-sub-clone { text-align: center; color: var(--muted); margin-bottom: 36px; font-size: 0.95rem; }

/* ══ HERO ══ */
.hero {
  position: relative; overflow: hidden;
  background: linear-gradient(160deg, var(--hero-bg-start) 0%, var(--hero-bg-end) 100%);
  padding-bottom: 0; font-family: 'Inter', sans-serif;
}
.hero-bg { position: absolute; inset: 0; pointer-events: none; z-index: 0; }
.shape {
  position: absolute; opacity: 0.55;
  animation: floatShape 5s ease-in-out infinite;
}
.shape-1 { width: 14px; height: 14px; background: #ff9800; top: 60px; left: 18%; border-radius: 3px; transform: rotate(45deg); animation-duration: 5.2s; }
.shape-2 { width: 20px; height: 20px; background: #e91e90; top: 100px; left: 38%; border-radius: 50%; animation-delay: 0.8s; animation-duration: 4.5s; }
.shape-3 { width: 16px; height: 16px; background: #9c27b0; top: 70px; right: 30%; border-radius: 4px; animation-delay: 1.4s; animation-duration: 6s; }
.shape-4 { width: 24px; height: 24px; background: #ff6b35; top: 120px; right: 18%; border-radius: 4px; animation-delay: 0.4s; animation-duration: 4.8s; }
.shape-5 { width: 12px; height: 12px; background: #4caf50; top: 200px; left: 10%; border-radius: 50%; animation-delay: 2s; animation-duration: 5.6s; }
@keyframes floatShape {
  0%,100% { transform: translateY(0) rotate(0deg); }
  33%      { transform: translateY(-10px) rotate(8deg); }
  66%      { transform: translateY(6px) rotate(-5deg); }
}

.hero-content {
  position: relative; z-index: 1;
  text-align: center; padding: 64px 24px 44px;
  animation: heroFadeIn 0.7s ease both;
  display: flex; flex-direction: column; align-items: center; gap: 20px;
}
@keyframes heroFadeIn {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Eyebrow */
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 7px;
  background: rgba(26,115,232,.1); color: var(--blue);
  border: 1px solid rgba(26,115,232,.18);
  padding: 5px 14px; border-radius: 20px;
  font-size: .75rem; font-weight: 600; letter-spacing: .02em;
}
.hero-eyebrow-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: #22c55e;
  box-shadow: 0 0 0 2px rgba(34,197,94,.25);
  animation: pulse 2s ease infinite;
}
@keyframes pulse {
  0%,100% { box-shadow: 0 0 0 2px rgba(34,197,94,.25); }
  50%      { box-shadow: 0 0 0 5px rgba(34,197,94,.1); }
}

.hero-title {
  font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 800;
  color: var(--text); line-height: 1.25; margin-bottom: 18px;
  letter-spacing: -0.5px;
}

/* ─ Typewriter highlight ─ */
.hero-highlight {
  display: inline;
  background: linear-gradient(135deg, #ff6b35 0%, #f97316 100%);
  color: white;
  /* padding horizontal only — altura = só o que a fonte pede */
  padding: 0.12em 0.5em;
  border-radius: 0.25em;
  vertical-align: baseline;
  box-shadow: 0 4px 20px rgba(249,115,22,0.4);
  position: relative;
  white-space: nowrap;
  /* shimmer via background */
  background-image: linear-gradient(105deg, rgba(255,255,255,0) 40%, rgba(255,255,255,0.12) 50%, rgba(255,255,255,0) 60%), linear-gradient(135deg, #ff6b35, #f97316);
  background-size: 200% 100%, 100% 100%;
  animation: shimmer 3s ease-in-out infinite;
}
@keyframes shimmer {
  0%   { background-position: 200% 0, 0 0; }
  100% { background-position: -200% 0, 0 0; }
}
.hero-word {
  font-weight: 800;
  font-size: inherit;
  line-height: inherit;
}
.hero-cursor {
  display: inline-block;
  width: 2px;
  height: 0.75em;
