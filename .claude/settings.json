{
  "projectName": "Small Web Apps",
  "permissions": {
    "allowed": [
      "git",
      "bash",
      "pnpm",
      "node",
      "npm"
    ]
  },
  "hooks": {
    "onBeforeCommit": "pnpm run type-check 2>/dev/null && echo '✓ Type check passed' || echo '⚠️  Type check warnings'"
  },
  "settings": {
    "defaultBuildCommand": "pnpm --dir apps/web run build",
    "defaultPreviewCommand": "pnpm --dir apps/web run dev",
    "outputDirectory": "apps/web/dist",
    "sourceDirectory": "apps/web/src"
  }
}
