---
---
<section class="hero">
  <div class="hero-bg">
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>
    <div class="shape shape-4"></div>
    <div class="shape shape-5"></div>
  </div>
  <div class="hero-content">
    <h1 class="hero-title">
      Free Tools to Make
      <span class="hero-highlight">
        <span class="rotating-words">
          <span class="word active">Your Life</span>
          <span class="word">Your Work</span>
          <span class="word">Every Day</span>
        </span>
      </span>
      Simple
    </h1>
    <p class="hero-sub">We offer PDF, video, image and other online tools to make your life easier</p>
    <div class="hero-search">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <input type="text" placeholder="Search" />
      <button class="search-btn">Search</button>
    </div>
  </div>

  <div class="category-cards">
    <a href="#" class="cat-card cat-purple">
      <div class="cat-badge">45+ tools</div>
      <div class="cat-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/></svg>
      </div>
      <div class="cat-info">
        <h3>PDF Tools</h3>
        <p>Solve Your PDF Problems</p>
      </div>
      <svg class="cat-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      <div class="cat-featured">Featured Tool: <span>PDF Creator</span></div>
    </a>

    <a href="#" class="cat-card cat-orange">
      <div class="cat-badge">30+ tools</div>
      <div class="cat-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
      </div>
      <div class="cat-info">
        <h3>Image Tools</h3>
        <p>Solve Your Image Problems</p>
      </div>
      <svg class="cat-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      <div class="cat-featured">Featured Tool: <span>Remove BG</span></div>
    </a>

    <a href="#" class="cat-card cat-red">
      <div class="cat-badge">10+ tools</div>
      <div class="cat-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><polygon points="23,7 16,12 23,17"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
      </div>
      <div class="cat-info">
        <h3>Video Tools</h3>
        <p>Solve Your Video Problems</p>
      </div>
      <svg class="cat-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      <div class="cat-featured">Featured Tool: <span>Mute Video</span></div>
    </a>

    <a href="#" class="cat-card cat-blue">
      <div class="cat-badge">10+ tools</div>
      <div class="cat-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      </div>
      <div class="cat-info">
        <h3>AI Write</h3>
        <p>Solve Your Text Problems</p>
      </div>
      <svg class="cat-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      <div class="cat-featured">Featured Tool: <span>Paragraph Writer</span></div>
    </a>

    <a href="#" class="cat-card cat-teal">
      <div class="cat-badge">15+ tools</div>
      <div class="cat-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z"/><polyline points="13,2 13,9 20,9"/></svg>
      </div>
      <div class="cat-info">
        <h3>File Tools</h3>
        <p>Solve Your File Problems</p>
      </div>
      <svg class="cat-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      <div class="cat-featured">Featured Tool: <span>Split Excel</span></div>
    </a>
  </div>

  <div class="stats-bar">
    <div class="stat"><span class="stat-num">1m</span><span class="stat-label">Active Users</span></div>
    <div class="stat-divider"></div>
    <div class="stat"><span class="stat-num">10m</span><span class="stat-label">Files Converted</span></div>
    <div class="stat-divider"></div>
    <div class="stat"><span class="stat-num">200+</span><span class="stat-label">Online Tools</span></div>
    <div class="stat-divider"></div>
    <div class="stat"><span class="stat-num">500k</span><span class="stat-label">PDFs Created</span></div>
  </div>
</section>

<style>
.hero {
  position: relative;
  overflow: hidden;
  padding-bottom: 0;
}
.hero-bg {
  position: absolute; inset: 0; pointer-events: none; z-index: 0;
}
.shape {
  position: absolute;
  border-radius: 50%;
  opacity: 0.5;
}
.shape-1 { width: 14px; height: 14px; background: #ff9800; top: 60px; left: 18%; border-radius: 3px; transform: rotate(45deg); }
.shape-2 { width: 20px; height: 20px; background: #e91e90; top: 100px; left: 38%; border-radius: 50%; }
.shape-3 { width: 16px; height: 16px; background: #9c27b0; top: 70px; right: 30%; }
.shape-4 { width: 24px; height: 24px; background: #ff6b35; top: 120px; right: 18%; border-radius: 4px; transform: rotate(20deg); }
.shape-5 { width: 12px; height: 12px; background: #4caf50; top: 200px; left: 10%; border-radius: 50%; }

.hero-content {
  position: relative; z-index: 1;
  text-align: center;
  padding: 64px 24px 40px;
}
.hero-title {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 800;
  color: #1a1a2e;
  line-height: 1.2;
  margin-bottom: 16px;
}
.hero-highlight {
  display: inline-block;
  background: #ff6b35;
  color: white;
  padding: 2px 16px;
  border-radius: 6px;
  position: relative;
  min-width: 240px;
  overflow: hidden;
}
.rotating-words { display: inline-block; }
.word { display: none; }
.word.active { display: inline; }

.hero-sub {
  color: #666;
  font-size: 1rem;
  margin-bottom: 28px;
}
.hero-search {
  display: flex;
  align-items: center;
  gap: 12px;
  max-width: 540px;
  margin: 0 auto;
  background: white;
  border: 1.5px solid var(--border);
  border-radius: 40px;
  padding: 10px 10px 10px 20px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}
.hero-search input {
  flex: 1; border: none; outline: none;
  font-size: 0.95rem; font-family: inherit; color: #333;
  background: transparent;
}
.hero-search input::placeholder { color: #bbb; }
.search-btn {
  background: var(--blue);
  color: white;
  padding: 10px 28px;
  border-radius: 30px;
  font-size: 0.9rem;
  font-weight: 600;
  transition: background 0.15s;
}
.search-btn:hover { background: var(--blue-dark); }

/* Category cards */
.category-cards {
  display: flex;
  gap: 16px;
  max-width: 1280px;
  margin: 40px auto 0;
  padding: 0 24px;
  overflow-x: auto;
  scrollbar-width: none;
}
.category-cards::-webkit-scrollbar { display: none; }
.cat-card {
  flex: 1;
  min-width: 200px;
  border-radius: 20px;
  padding: 20px;
  color: white;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 8px;
  transition: transform 0.2s, box-shadow 0.2s;
  cursor: pointer;
}
.cat-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.18); }
.cat-purple { background: linear-gradient(135deg, #7c3aed, #5b21b6); }
.cat-orange { background: linear-gradient(135deg, #f97316, #ea580c); }
.cat-red { background: linear-gradient(135deg, #e11d48, #be123c); }
.cat-blue { background: linear-gradient(135deg, #2563eb, #1d4ed8); }
.cat-teal { background: linear-gradient(135deg, #0d9488, #0f766e); }

.cat-badge {
  position: absolute;
  top: 14px; right: 14px;
  background: rgba(255,255,255,0.25);
  font-size: 0.72rem;
  font-weight: 600;
  padding: 3px 10px;
  border-radius: 20px;
}
.cat-icon {
  background: rgba(255,255,255,0.2);
  width: 50px; height: 50px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.cat-info h3 { font-size: 1rem; font-weight: 700; }
.cat-info p { font-size: 0.78rem; opacity: 0.85; }
.cat-arrow { margin-top: auto; }
.cat-featured {
  font-size: 0.73rem;
  background: rgba(0,0,0,0.2);
  padding: 6px 12px;
  border-radius: 10px;
  margin-top: 4px;
}
.cat-featured span { font-weight: 700; }

/* Stats */
.stats-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 0;
  background: white;
  border-top: 1px solid var(--border);
  margin-top: 40px;
  padding: 24px;
}
.stat {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 0 40px;
}
.stat-num {
  font-size: 2rem;
  font-weight: 800;
  color: var(--blue);
}
.stat-label { font-size: 0.85rem; color: #666; }
.stat-divider { width: 1px; height: 40px; background: var(--border); }
</style>
